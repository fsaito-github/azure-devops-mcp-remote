# Azure DevOps MCP - Environment Configuration Example
# Copy this file to .env.local and fill in your values

# Application
NODE_ENV=production
LOG_LEVEL=info
PORT=8080
DEBUG_PORT=5005

# Azure DevOps Configuration
AZURE_DEVOPS_ORG=your-org
# AZURE_DEVOPS_PAT=your-personal-access-token

# OAuth2 / Azure AD (for Phase 2)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_TENANT_ID=your-tenant-id
# OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback

# Remote deployment - Host validation
# Comma-separated list of allowed hostnames (e.g., myapp.eastus2.azurecontainer.io)
# Omit to disable host restriction when using HTTP/SSE transport
# ALLOWED_HOSTS=myapp.eastus2.azurecontainer.io

# Docker Compose
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
