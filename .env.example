NODE_ENV=production
LOG_LEVEL=info
PORT=8080
DEBUG_PORT=5005

# Azure DevOps Organization
AZURE_DEVOPS_ORG=your-org

# Authentication via PAT Token (--authentication envvar)
# ADO_MCP_AUTH_TOKEN=your-personal-access-token

# Authentication via OBO Flow (--authentication obo)
# Requires Azure AD App Registration (see docs/AZURE-AD-SETUP.md)
# OAUTH_CLIENT_ID=your-app-client-id
# OAUTH_CLIENT_SECRET=your-app-client-secret
# OAUTH_TENANT_ID=your-azure-ad-tenant-id
# OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback

# JWT Secret for session management (OBO mode)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your-random-secret

# Remote deployment - Host validation
# Comma-separated list of allowed hostnames (e.g., myapp.eastus2.azurecontainer.io)
# Omit to disable host restriction when using HTTP/SSE transport
# ALLOWED_HOSTS=myapp.eastus2.azurecontainer.io

# Docker
DOCKER_BUILDKIT=1
